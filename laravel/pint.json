{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": true,
        "no_unused_imports": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "no_empty_phpdoc": true,
        "phpdoc_align": {
            "align": "vertical"
        },
        "single_quote": true,
        "concat_space": {
            "spacing": "one"
        }
    },
    "exclude": [
        "bootstrap/cache",
        "storage",
        "vendor",
        "node_modules"
    ]
}
