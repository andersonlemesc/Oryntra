includes:
    - ./vendor/larastan/larastan/extension.neon
    - ./phpstan-baseline.neon

parameters:
    paths:
        - app
        - config
        - database
        - routes
        - tests
    level: 8
    excludePaths:
        - bootstrap/cache/*
        - storage/*
        - vendor/*
    treatPhpDocTypesAsCertain: false
