# ============================================================
# Oryntra — development env. Ready to run out of the box:
#   cp .env.example .env && docker compose up -d
# All values below are safe local defaults. Override for production.
# ============================================================

# ----- App identity -----
APP_NAME=Oryntra
APP_ENV=local
# Throwaway dev key (regenerate for production: php artisan key:generate).
APP_KEY=base64:uEW0+rZhSZhL+qdUOZrwu8+8bbWjWItPFOxGP6bpyOM=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=UTC                    # default; override per deployment
APP_LOCALE=en                       # default UI language; supports en, pt_BR, es, etc.

# ----- Postgres -----
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=oryntra
DB_USERNAME=oryntra
DB_PASSWORD=oryntra_dev_pw          # CHANGE in production

# ----- Redis (queues, cache, locks, Reverb) -----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# ----- Horizon -----
HORIZON_PREFIX=oryntra_horizon:
HORIZON_PATH=horizon

# ----- Reverb (WebSocket) -----
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=oryntra
REVERB_APP_KEY=local_reverb_key
REVERB_APP_SECRET=local_reverb_secret
REVERB_HOST=laravel-reverb
REVERB_PORT=8081
REVERB_SCHEME=http

# ----- MinIO (S3-compatible storage) -----
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=oryntra_minio
AWS_SECRET_ACCESS_KEY=oryntra_minio_pw
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=oryntra-storage
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
MINIO_ROOT_USER=oryntra_minio
MINIO_ROOT_PASSWORD=oryntra_minio_pw

# ----- Mail (Mailpit dev) -----
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=no-reply@oryntra.local
MAIL_FROM_NAME="${APP_NAME}"

# ----- Logging -----
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ----- Telescope / Pulse / Horizon dashboards (dev open) -----
TELESCOPE_ENABLED=true

# ----- Internal Python service -----
AGENT_PYTHON_URL=http://agent-python:8000
# Dev default — Laravel and the Python runtime must share the same value.
# Generate a strong one for production.
INTERNAL_API_TOKEN=dev_internal_c5cdb804599d4b6fd840c877ce627e03

# ----- Async agent runtime & scaling (perfil "server médio": 4 vCPU / 16GB) -----
# Fluxo: Laravel dispara o run (fila `agent`), Python roda e devolve via callback.
# Tetos compartilhados (escala horizontal); ajuste juntos os dois lados.
#
# Concorrência de runs LLM = min(HORIZON_AGENT_MAX, UVICORN_WORKERS*AGENT_MAX_CONCURRENCY)
HORIZON_AGENT_MAX=24
UVICORN_WORKERS=4
AGENT_MAX_CONCURRENCY=8
# Fatia justa por workspace/tenant (anti noisy-neighbor) na fila `agent`.
AGENT_MAX_CONCURRENCY_PER_ACCOUNT=3
# Run sem callback além disso (s) é considerado travado e marcado Failed pelo reaper.
AGENT_RUN_TIMEOUT=180
# Timeout (s) do POST de dispatch Laravel→Python (só o accept 202, não o run).
AGENT_RUNTIME_ACCEPT_TIMEOUT=10
# pgbouncer: em produção aponte o Laravel ao pooler (workers Horizon compartilham
# poucas conexões). Python fica direto no postgres (checkpointer usa prepared stmts).
LARAVEL_DB_HOST=postgres
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=25

# ----- Chatwoot platform-level integration -----
# Token super-admin pra sync de accounts/users via Platform API.
# Gerar em Chatwoot self-hosted: Super Admin Console → Platform Apps.
CHATWOOT_PLATFORM_TOKEN=
CHATWOOT_PLATFORM_BASE_URL=http://host.docker.internal:3000

# ----- Postgres URL alternativa pra Python (langgraph-checkpoint-postgres) -----
POSTGRES_URL=postgresql://oryntra:oryntra_dev_pw@postgres:5432/oryntra
LANGGRAPH_CHECKPOINTER=postgres

# ----- Google Calendar OAuth (Fase 17) -----
# Cria 1 projeto Google Cloud + ativa Calendar API + OAuth Client (Web app).
# Redirect URI deve bater com a rota /oauth/google-calendar/callback do APP_URL.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8080/oauth/google-calendar/callback
GOOGLE_CALENDAR_APP_NAME=Oryntra
