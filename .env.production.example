# =============================================================================
# Oryntra — production .env (MODEST profile: mostly one account, low traffic)
#
# Topology: managed Postgres + Redis (external), existing external Traefik for
# TLS/routing, MinIO internal. Copy to .env, fill the secrets, then:
#
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d \
#     nginx laravel-app laravel-horizon laravel-scheduler laravel-reverb \
#     agent-python minio
#
# The runtime box only needs to fit the app + agent + minio (~2GB idle).
# =============================================================================

# ----- Image tag -----
# Which published image tag the prod compose pulls (Docker Hub:
# andersonlemes/oryntra, -agent, -nginx). The Deploy workflow sets this to the
# released version (e.g. 1.2.0). Pin a version here for manual deploys/rollback;
# `latest` tracks the newest release.
DEPLOY_TAG=latest

# ----- App -----
APP_NAME=Oryntra
APP_ENV=production
APP_KEY=                       # php artisan key:generate
APP_DEBUG=false
APP_URL=https://app.your-domain.com
APP_TIMEZONE=UTC
APP_LOCALE=en

# ----- Edge routing (existing external Traefik) -----
# Public host; must match the cert and the DNS record pointing at Traefik.
APP_DOMAIN=app.your-domain.com
# Name of the EXISTING external Traefik docker network this stack joins.
TRAEFIK_NETWORK=traefik
# Traefik https entrypoint and cert resolver names (as configured in Traefik).
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt

# ----- Database (managed Postgres, external) -----
DB_CONNECTION=pgsql
DB_DATABASE=oryntra
DB_USERNAME=oryntra
DB_PASSWORD=change_me_strong_password
DB_PORT=5432
# Host of the managed Postgres. The Laravel tier connects here directly.
LARAVEL_DB_HOST=your-managed-postgres-host
# Python connects directly too. The LangGraph checkpointer needs server-side
# prepared statements, so this MUST be a direct connection (or a session-mode
# pooler) — never a transaction-mode pooler.
POSTGRES_URL=postgresql://oryntra:change_me_strong_password@your-managed-postgres-host:5432/oryntra
LANGGRAPH_CHECKPOINTER=postgres

# ----- Redis (managed, external) -----
REDIS_HOST=your-managed-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
QUEUE_CONNECTION=redis
HORIZON_PATH=horizon
# Worker ceilings (autoscale up to these under load; idle drops to ~1 each).
HORIZON_AGENT_MAX=3
HORIZON_CHATWOOT_WEBHOOKS_MAX=2
HORIZON_BACKGROUND_MAX=2

# ----- Reverb (websocket, served on APP_DOMAIN/app via Traefik) -----
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=oryntra
REVERB_APP_KEY=change_me_reverb_key
REVERB_APP_SECRET=change_me_reverb_secret
# Client-facing endpoint (browser connects wss://APP_DOMAIN/app). TLS is at Traefik.
REVERB_HOST=app.your-domain.com
REVERB_PORT=443
REVERB_SCHEME=https
# Server bind (inside the container, behind Traefik).
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8081
# Vite build-time mirror of the above (baked into the frontend assets at build).
VITE_REVERB_APP_KEY=${REVERB_APP_KEY}
VITE_REVERB_HOST=${REVERB_HOST}
VITE_REVERB_PORT=${REVERB_PORT}
VITE_REVERB_SCHEME=${REVERB_SCHEME}

# ----- Internal Python agent runtime -----
AGENT_PYTHON_URL=http://agent-python:8000
INTERNAL_API_TOKEN=generate_a_long_random_string
AGENT_RUNTIME_INTERNAL_TOKEN=${INTERNAL_API_TOKEN}
# Python execution slots = UVICORN_WORKERS * AGENT_MAX_CONCURRENCY (2 * 8 = 16).
UVICORN_WORKERS=2
AGENT_MAX_CONCURRENCY=8
# Fair share per account on the shared `agent` queue.
AGENT_MAX_CONCURRENCY_PER_ACCOUNT=5
# A run with no callback past this many seconds is reaped as failed.
AGENT_RUN_TIMEOUT=180
# Timeout (s) for the dispatch accept (202) — not the whole run.
AGENT_RUNTIME_ACCEPT_TIMEOUT=10
LOG_LEVEL=INFO

# ----- Observability (optional, opt-in) -----
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=oryntra-agent

# ----- Object storage (MinIO, internal-only) -----
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=oryntra-storage
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
MINIO_ROOT_USER=oryntra_minio
MINIO_ROOT_PASSWORD=change_me_minio_password

# ----- Mail (use a REAL SMTP in production; mailpit is dev-only) -----
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@your-domain.com

# ----- Chatwoot platform integration -----
CHATWOOT_PLATFORM_TOKEN=
CHATWOOT_PLATFORM_BASE_URL=https://your-chatwoot-host
