# =============================================================================
# Oryntra — production .env (MODEST profile: mostly one account, low traffic)
# Copy to .env, fill the secrets, then:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d \
#     nginx laravel-app laravel-horizon laravel-scheduler laravel-reverb \
#     agent-python postgres pgbouncer redis minio
# Target box: 4 vCPU / 8GB (works on 4GB at this scale).
# =============================================================================

# ----- App -----
APP_NAME=Oryntra
APP_ENV=production
APP_KEY=                       # php artisan key:generate
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_TIMEZONE=UTC
APP_LOCALE=en

# ----- Database (Laravel goes through pgbouncer; Python stays direct) -----
DB_CONNECTION=pgsql
DB_DATABASE=oryntra
DB_USERNAME=oryntra
DB_PASSWORD=change_me_strong_password
# Laravel tier connects via the pooler (set to `postgres` to bypass it).
LARAVEL_DB_HOST=pgbouncer
DB_PORT=5432
PGBOUNCER_MAX_CLIENT_CONN=500
PGBOUNCER_DEFAULT_POOL_SIZE=20

# ----- Redis / queues / Horizon -----
REDIS_HOST=redis
QUEUE_CONNECTION=redis
HORIZON_PATH=horizon
# Worker ceilings (autoscale up to these under load; idle drops to ~1 each).
# 3 supervisors total: agent + chatwoot-webhooks + background.
HORIZON_AGENT_MAX=3
HORIZON_CHATWOOT_WEBHOOKS_MAX=2
HORIZON_BACKGROUND_MAX=2

# ----- Internal Python agent runtime -----
AGENT_PYTHON_URL=http://agent-python:8000
INTERNAL_API_TOKEN=generate_a_long_random_string
AGENT_RUNTIME_INTERNAL_TOKEN=${INTERNAL_API_TOKEN}
# Python execution slots = UVICORN_WORKERS * AGENT_MAX_CONCURRENCY.
# 2 * 8 = 16 concurrent runs — generous for one small account.
UVICORN_WORKERS=2
AGENT_MAX_CONCURRENCY=8
# Fair share per account on the shared `agent` queue. For a single dominant
# account keep this comfortably below total slots (raise if it gets throttled).
AGENT_MAX_CONCURRENCY_PER_ACCOUNT=5
# A run with no callback past this many seconds is reaped as failed.
AGENT_RUN_TIMEOUT=180
# Timeout (s) for the dispatch accept (202) — not the whole run.
AGENT_RUNTIME_ACCEPT_TIMEOUT=10
# Python connects directly to Postgres (LangGraph checkpointer needs prepared
# statements — do not point this at pgbouncer in transaction mode).
POSTGRES_URL=postgresql://oryntra:change_me_strong_password@postgres:5432/oryntra
LANGGRAPH_CHECKPOINTER=postgres
LOG_LEVEL=INFO

# ----- Observability (optional, opt-in) -----
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=oryntra-agent

# ----- Object storage (MinIO self-hosted, or point at real S3) -----
MINIO_ROOT_USER=oryntra_minio
MINIO_ROOT_PASSWORD=change_me_minio_password

# ----- Mail (use a REAL SMTP in production; mailpit is dev-only) -----
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@your-domain.com

# ----- Chatwoot platform integration -----
CHATWOOT_PLATFORM_TOKEN=
CHATWOOT_PLATFORM_BASE_URL=https://your-chatwoot-host
