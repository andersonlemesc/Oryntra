# =============================================================================
# Oryntra — .env de exemplo para o stack Swarm (docker-stack.yml)
#
# Copie para .env, preencha, depois:
#   set -a && . ./.env && set +a
#   docker stack deploy -c docker-stack.yml oryntra
# =============================================================================

# Tag das imagens publicadas no Docker Hub (andersonlemes/oryntra-*).
ORYNTRA_VERSION=latest

# ----- App -----
APP_NAME=Oryntra
# Gere uma vez com:  docker run --rm andersonlemes/oryntra:latest php artisan key:generate --show
APP_KEY=

# ----- Domínio + Traefik (já existente no swarm) -----
APP_DOMAIN=app.seu-dominio.com
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt

# ----- Postgres externo (precisa da extensão pgvector) -----
# A SENHA não vai aqui — vem do Docker secret `postgres_password`:
#   printf 'sua_senha' | docker secret create postgres_password -
# O app lê via DB_PASSWORD_FILE; o agent monta a POSTGRES_URL a partir de DB_*
# + o secret. Conexão direta (prepared statements) — NÃO use pooler transaction.
DB_HOST=seu-postgres-host
DB_PORT=5432
DB_DATABASE=oryntra
DB_USERNAME=oryntra

# ----- Redis externo -----
REDIS_HOST=seu-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=

# ----- Storage S3 (MinIO próprio ou S3 da AWS) -----
AWS_ACCESS_KEY_ID=sua_access_key
AWS_SECRET_ACCESS_KEY=sua_secret_key
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=oryntra-storage
AWS_ENDPOINT=https://seu-s3-endpoint
AWS_USE_PATH_STYLE_ENDPOINT=true

# ----- Runtime Python (interno) -----
INTERNAL_API_TOKEN=gere_uma_string_longa_aleatoria
UVICORN_WORKERS=2
AGENT_MAX_CONCURRENCY=8
AGENT_MAX_CONCURRENCY_PER_ACCOUNT=5
AGENT_RUN_TIMEOUT=180
LOG_LEVEL=INFO

# ----- Horizon (tetos de worker) -----
HORIZON_AGENT_MAX=3
HORIZON_CHATWOOT_WEBHOOKS_MAX=2
HORIZON_BACKGROUND_MAX=2

# ----- Reverb (websocket) -----
REVERB_APP_ID=oryntra
REVERB_APP_KEY=gere_uma_chave
REVERB_APP_SECRET=gere_um_secret
